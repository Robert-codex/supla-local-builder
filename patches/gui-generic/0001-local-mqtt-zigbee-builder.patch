+#include <ZigbeeGateway.h>
+
+namespace Supla::GUI {
+
+class ZigbeeGatewayMode {
+ public:
+  static void setup();
+  static void iterate();
+
+ private:
+  static bool configured;
+  static bool started;
+  static bool coexist_enabled;
+  static ZigbeeGateway gateway;
+};
+
+}  // namespace Supla::GUI
+
+#else
+
+namespace Supla::GUI {
+
+class ZigbeeGatewayMode {
+ public:
+  static void setup() {}
+  static void iterate() {}
+};
+
