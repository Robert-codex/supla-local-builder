+#ifndef SuplaZigbeeGateway_h
+#define SuplaZigbeeGateway_h
+
+#if defined(ARDUINO_ARCH_ESP32)
+#include <sdkconfig.h>
+#endif
+
+#if defined(SUPLA_ZIGBEE_GATEWAY) && defined(CONFIG_IDF_TARGET_ESP32C6)
+
+#include <SuplaDevice.h>
