+
+class BL_0930 : public OnePhaseElectricityMeter {
+ public:
+  explicit BL_0930(int8_t pinCF);
+
+  void onInit();
+  void readValuesFromDevice();
+  void onSaveState();
+  void onLoadState();
+
+  _supla_int64_t getCounter() const;
+  void setCounter(_supla_int64_t value);
